+WRAPPER_SDKROOT="${SDKROOT:-}"
+if [[ -z "${WRAPPER_SDKROOT}" || ! -d "${WRAPPER_SDKROOT}" ]] ; then
+  WRAPPER_SDKROOT="$(DEVELOPER_DIR="${WRAPPER_DEVDIR}" /usr/bin/xcrun --sdk macosx --show-sdk-path)"
